# Girls Made Pudding Cookbook — Cloudflare Pages headers
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# Recipe & ingredient art never changes for a given pathID-based filename,
# so it's safe to cache aggressively at the edge and in browsers.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Polaroid / item_slot frames are versioned by path too, same rule.
/assets/ui/*
  Cache-Control: public, max-age=31536000, immutable

# Recipe + translation data gets regenerated when the game updates, so
# keep TTLs short enough that a redeploy is visible within minutes.
/data/*
  Cache-Control: public, max-age=300, must-revalidate

# Scripts/stylesheets don't have content hashes in their filenames yet,
# so don't long-cache them. 5 minutes at the edge is plenty.
/app.js
  Cache-Control: public, max-age=300, must-revalidate
/style.css
  Cache-Control: public, max-age=300, must-revalidate

# HTML must always revalidate so users see new text/structure immediately.
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Baseline security headers. Nothing here is framed/embedded or loaded
# cross-origin, so we can be strict.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: interest-cohort=()
